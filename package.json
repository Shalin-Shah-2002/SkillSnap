{
  "name": "youtube-skill-maker-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Chrome MV3 extension that turns captioned YouTube videos into Codex and Claude skill ZIPs using Gemini.",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jszip": "3.10.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "0.0.287",
    "@types/node": "22.7.4",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "esbuild": "0.28.0",
    "typescript": "5.6.3",
    "vitest": "4.1.7"
  }
}
